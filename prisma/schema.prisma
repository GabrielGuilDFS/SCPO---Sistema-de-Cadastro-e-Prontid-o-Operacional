// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfilAcesso {
  ADMINISTRADOR
  OPERADOR
  VISUALIZADOR

  @@map("perfil_acesso")
}

enum CnhCategoria {
  A
  B
  C
  D
  E
  AB
  AC
  AD
  AE

  @@map("cnh_categoria")
}

enum GrauHierarquico {
  SOLDADO
  CABO
  SARGENTO
  SUBTENENTE
  TENENTE
  CAPITAO
  MAJOR
  TENENTE_CORONEL
  CORONEL

  @@map("grau_hierarquico")
}

enum Sexo {
  MASCULINO
  FEMININO

  @@map("sexo")
}

enum TipoSanguineo {
  A_POSITIVO   @map("A+")
  A_NEGATIVO   @map("A-")
  B_POSITIVO   @map("B+")
  B_NEGATIVO   @map("B-")
  AB_POSITIVO  @map("AB+")
  AB_NEGATIVO  @map("AB-")
  O_POSITIVO   @map("O+")
  O_NEGATIVO   @map("O-")

  @@map("tipo_sanguineo")
}

enum EstadoCivil {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO

  @@map("estado_civil")
}

enum Escolaridade {
  FUNDAMENTAL
  MEDIO
  SUPERIOR
  POS_GRADUACAO
  MESTRADO
  DOUTORADO

  @@map("escolaridade")
}

model Login {
  id           Int          @id @default(autoincrement())
  policialId   Int          @unique @map("policial_id")
  perfilAcesso PerfilAcesso @map("perfil_acesso")
  matricula    String       @unique @db.VarChar(50)
  senhaHash    String       @map("senha_hash") @db.VarChar(255)
  statusAtivo  Boolean      @default(true) @map("status_ativo")
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  policial Policial @relation(fields: [policialId], references: [id])

  @@map("login")
}

model Subunidade {
  id              Int               @id @default(autoincrement())
  nome            String            @unique
  sigla           String            @unique
  policiais       Policial[]
  postosServico   PostoDeServico[]
  transferencias  Transferencia[]

  @@map("subunidade")
}

model PostoDeServico {
  id           Int        @id @default(autoincrement())
  nome         String     @unique
  subunidadeId Int        @map("subunidade_id")
  subunidade   Subunidade @relation(fields: [subunidadeId], references: [id])

  @@map("posto_de_servico")
}

model FuncaoAtual {
  id        Int        @id @default(autoincrement())
  funcao    String     @unique
  policiais Policial[]

  @@map("funcao_atual")
}

model Transferencia {
  id              Int        @id @default(autoincrement())
  policialId      Int        @map("policial_id")
  subunidadeId    Int        @map("subunidade_id")
  dataTransferencia DateTime   @default(now()) @map("data_transferencia")
  
  subunidade      Subunidade @relation(fields: [subunidadeId], references: [id])
  policial        Policial   @relation(fields: [policialId], references: [id])

  @@map("transferencia")
}

model Endereco {
  id         Int        @id @default(autoincrement())
  logradouro String?
  numero     String?
  bairro     String?
  cidade     String?
  estado     String?
  cep        String?
  
  policiais  Policial[]

  @@map("endereco")
}

model Policial {
  id              Int          @id @default(autoincrement())
  nomeCompleto    String       @map("nome_completo")
  nomeGuerra      String?      @map("nome_guerra")
  matricula       String       @unique
  cpf             String       @unique @db.Char(11)
  rg              String
  cnhCategoria    CnhCategoria? @map("cnh_categoria")
  cnhNumero       String?       @map("cnh_numero") @db.VarChar(20)
  dataAdmissao    DateTime      @map("data_admissao") @db.Date
  grauHierarquico GrauHierarquico? @map("grau_hierarquico")
  possuiPlanoSaude Boolean?     @default(false) @map("possui_plano_saude")
  dataNascimento  DateTime      @map("data_nascimento") @db.Date
  sexo            Sexo?
  tipoSanguineo   TipoSanguineo? @map("tipo_sanguineo")
  estadoCivil     EstadoCivil?   @map("estado_civil")
  escolaridade    Escolaridade?
  religiosidade   String?
  telefonePrimario String       @map("telefone_primario")
  telefoneSecundario String?    @map("telefone_secundario")
  email           String?
  observacoes     String?       @db.Text
  idade           Int?
  status          String?      @default("pronto")
  imagemUrl       String?      @map("imagem_url") @db.VarChar(255)
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @default(now()) @updatedAt @map("atualizado_em")

  enderecoId      Int?         @unique @map("endereco_id")
  endereco        Endereco?    @relation(fields: [enderecoId], references: [id])

  subunidadeId    Int?         @map("subunidade_id")
  subunidade      Subunidade?  @relation(fields: [subunidadeId], references: [id])
  
  funcaoAtualId   Int?         @map("funcao_atual_id")
  funcaoAtual     FuncaoAtual? @relation(fields: [funcaoAtualId], references: [id])
  transferencias  Transferencia[]

  login Login?

  @@map("policial")
}
